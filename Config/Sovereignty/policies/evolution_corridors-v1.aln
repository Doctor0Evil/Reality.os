# MONOTONIC EVOLUTION CONSTRAINTS — NON-NEGOTIABLE
# =============================================================================
# metric,domain,module,constraint_type,rule,enforcement,penalty,source
monotonic_constraint,host,rohmodel,kf_non_decrease,kf_after >= kf_before,hard_fail,evolution_rejected,"monotonic-evolution-spec-v1"
monotonic_constraint,host,rohmodel,roh_non_increase,roh_after <= roh_before,hard_fail,evolution_rejected,"monotonic-evolution-spec-v1"
monotonic_constraint,host,rohmodel,kf_floor_persistence,kf_floor = max(all kf_after),hard_fail,evolution_rejected,"monotonic-evolution-spec-v1"
monotonic_constraint,host,rohmodel,roh_ceiling_persistence,roh_ceiling = min(all roh_after),hard_fail,evolution_rejected,"monotonic-evolution-spec-v1"
monotonic_constraint,host,rohmodel,chain_continuity,kf_before == parent.kf_after,hard_fail,evolution_rejected,"evolution-chain-spec-v1"
monotonic_constraint,host,rohmodel,chain_continuity_roh,roh_before == parent.roh_after,hard_fail,evolution_rejected,"evolution-chain-spec-v1"
monotonic_constraint,host,rohmodel,non_reversibility,no_kf_decrease_from_any_previous_state,hard_fail,evolution_rejected,"non-reversibility-spec-v1"
monotonic_constraint,host,rohmodel,non_reversibility_roh,no_roh_increase_from_any_previous_state,hard_fail,evolution_rejected,"non-reversibility-spec-v1"
